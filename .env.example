# Bot token is used ONLY on the backend (server/). Never put it in frontend or Vite env.
# In server folder: create .env with BOT_TOKEN=your_bot_token_after_regenerating

# Optional: backend URL for score/leaderboard (frontend)
# VITE_API_URL=https://your-api.com

# Optional: bot username for links (frontend-safe)
# VITE_APP_TELEGRAM_BOT_USERNAME=YourBot

# Ngrok tunnel (npm run tunnel) — https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken
