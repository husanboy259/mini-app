# Bot token is used ONLY on the backend (server/). Never put it in frontend or Vite env.
# In server folder: create .env with BOT_TOKEN=your_bot_token_after_regenerating

# Optional: backend URL for score/leaderboard (frontend)
# VITE_API_URL=https://your-api.com

# Optional: bot username for links (frontend-safe)
# VITE_APP_TELEGRAM_BOT_USERNAME=YourBot

# Ngrok tunnel (npm run tunnel) — https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken

# Supabase (Fast Food menyu — frontend)
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Backend (server/.env): buyurtma botga yuborish uchun
# BOT_TOKEN=...
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=service_role_key (Dashboard → Settings → API)
# ADMIN_TELEGRAM_ID=5803735374
# Frontend uchun backend manzili: VITE_API_URL=http://localhost:3002
# Finish tugmasi uchun Telegram webhook (serverni deploy qilgach):
#   https://api.telegram.org/bot<BOT_TOKEN>/setWebhook?url=https://YOUR_DOMAIN/api/telegram-webhook

# SMS (Twilio): foydalanuvchi "Yuborsin" bosganda admin raqamiga SMS (server/.env)
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890
# SMS_ADMIN_PHONE=+998901234567
